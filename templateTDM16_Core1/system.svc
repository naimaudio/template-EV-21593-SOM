			<product name="Analog Devices System Services and Device Drivers" version="1.0.0"/>
		</component>
		<component id="com.analog.crosscore.addins.ssldd.spu.sharcxi" name="SPU Service for SHARC" version="1.0.0" visible="true">
			<component-description><![CDATA[This add-in provides Analog Devices' implementation of the System Protection Unit(SPU)]]></component-description>
			<product name="Analog Devices System Services and Device Drivers" version="1.0.0"/>
		</component>
		<component id="com.analog.crosscore.addins.mcapi" name="Analog Devices' MCAPI" version="1.0.0" visible="true">
			<component-description><![CDATA[This add-in provides Analog Devices' implementation of Multicore association's Multicore Communications API (MCAPI™) version 2.15]]></component-description>
			<product name="Analog Devices implementation of Multicore Communications API (MCAPI™) v2.15" version="1.0.0"/>
		</component>
		<component id="com.analog.crosscore.addins.ssldd.pcg.sharcxi" name="PCG Service for SHARC" version="1.0.0" visible="true">
			<component-description><![CDATA[This add-in provides Analog Devices' implementation of the Precision Clock Generator (PCG) Service]]></component-description>
			<product name="Analog Devices System Services and Device Drivers" version="1.0.0"/>
		</component>
		<component id="com.analog.crosscore.addins.ssldd.asrc.sc59x.sharcxi" name="ASRC Driver for SHARC" version="2.0.1" visible="true">
			<component-description><![CDATA[This add-in provides Analog Devices' implementation of the Asynchronous Rate Converter (ASRC) Driver]]></component-description>
			<product name="Analog Devices System Services and Device Drivers" version="1.0.0"/>
		</component>
		<component id="com.analog.crosscore.addins.ssldd.asrc.common.sharcxi" name="ASRC Driver for SHARC" version="1.0.0" visible="false">
			<component-description><![CDATA[This add-in provides Analog Devices' implementation of the Asynchronous Rate Converter (ASRC) Driver]]></component-description>
			<product name="Analog Devices System Services and Device Drivers" version="1.0.0"/>
		</component>
	</installedComponents>
	<configurations>
		<configuration id="com.analog.crosscore.ssldd.pinmux.component">
			<pinmux-configuration processor="ADSP-21593" version="1.0">
				<peripheral description="Two-Wire Interface" name="TWI2">
					<signal bit="28" mux="0" name="SCL" pin="14" port="A"/>
					<signal bit="30" mux="0" name="SDA" pin="15" port="A"/>
				</peripheral>
				<gpio name="Port A">
					<signal bit="28" name="PA14" pin="14" port="A"/>
					<signal bit="30" name="PA15" pin="15" port="A"/>
				</gpio>
			</pinmux-configuration>
		</configuration>
